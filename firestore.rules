rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /visitors/{fingerprintId} {
      allow read: if false;
      allow create: if fingerprintId.size() == 32
        && request.resource.data.keys().hasAll(['firstSeen', 'lastSeen']);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstSeen', 'lastSeen']);
      allow delete: if false;

      match /projects/{projectId} {
        allow read: if false;
        allow create: if request.resource.data.keys().hasAll(['firstSeen', 'lastSeen']);
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen']);
        allow delete: if false;

        match /pages/{pageKey} {
          allow read: if false;
          allow create: if request.resource.data.keys().hasAll(['firstSeen', 'lastSeen']);
          allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen']);
          allow delete: if false;
        }
      }
    }

    match /projects/{projectId} {
      match /stats/{doc} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['total', 'unique', 'todayCount', 'todayDate']);
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total', 'unique', 'todayCount', 'todayDate']);
        allow delete: if false;
      }

      match /pages/{pageKey} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['pageKey', 'total', 'unique']);
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total', 'unique']);
        allow delete: if false;
      }

      match /ratings/{ratingId} {
        allow read: if true;
        allow create, update: if request.resource.data.keys().hasAll(['pageKey', 'fingerprintId', 'score', 'ts'])
          && request.resource.data.score is int
          && request.resource.data.score >= 1
          && request.resource.data.score <= 5;
        allow delete: if false;
      }

      match /issues/{issueId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['pageKey', 'fingerprintId', 'category', 'comment', 'ts'])
          && request.resource.data.category is string
          && request.resource.data.comment is string;
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
